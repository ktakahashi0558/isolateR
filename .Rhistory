#####----------k-means clustering（rRNAなし、vstしたデータをz-scoreに換算して実行）----------#####
# サンプル情報に基づいて各時間の平均を計算
# vst_matrixの行列をデータフレームに変換し、遺伝子名も列として持つ
vsd_long <- cluster_vst_Norrna %>%
as.data.frame() %>%
rownames_to_column(var = "gene_id") %>%
pivot_longer(col = -gene_id, names_to = "sample_id", values_to = "count")
# サンプル情報を結合して時間ごとに平均を取る
vsd_avg <- vsd_long %>%
inner_join(sample, by = "sample_id") %>%
dplyr::select(-sample) %>%
group_by(gene_id, sample_type) %>%  # gene_idと時間でグループ化
summarize(mean_count = mean(count)) %>%
pivot_wider(names_from = sample_type, values_from = mean_count) %>% # 時間を列に戻す
column_to_rownames("gene_id")
# z-scoreに変換
Z <- t(scale(t(vsd_avg)))
# k-means clustering
# エルボー法によるクラスタ数の決定
# cluster数 1~kの場合のkmeansを実施し、クラスター内平方和の総和を記録していく
# kmeansの結果のwithinssのところに各クラスターのクラスター内平方和がある。
k <- 30
wss <- sapply(1:k, function(i){kmeans(Z, centers=i, iter.max = 30)$tot.withinss})
# エルボー法のプロット
plot(1:30, wss, type = "b", pch = 19, frame = FALSE,
xlab = "Number of clusters K",
ylab = "Total within-clusters sum of squares")
# クラスタリング（7で）
set.seed(11)  # 再現性を確保するためのランダムシード
k_clusters <- 7  # エルボー法の結果から
kmeans_result <- kmeans(Z, centers = k_clusters, iter.max = 50)
# 結果の確認
head(kmeans_result$cluster)  # 各遺伝子がどのクラスタに属するか
# add cluster info to orig matrix
vsd_avg_with_cust_info <- as.data.frame(Z) %>%
mutate(clust = paste("cluster", kmeans_result$cluster,sep = ""))
## visualise each cluster
vsd_avg_with_cust_info %>%
gather(key = "variable" , value = "value", -clust) %>%  # 'clust'は対象から除く
group_by(variable) %>%
mutate(row_num =  1:n()) %>%
ggplot(aes(x =  variable , y = value , group = row_num)) +
geom_point() +
geom_line(alpha = 1 , aes(col = as.character(clust))) +
theme_bw() +
theme(legend.position = "none" , axis.text.x = element_text(angle = 90 , vjust = 0.4)) +
facet_wrap(~clust)
# prepare centroids
centers <- as.data.frame(kmeans_result$centers)
# クラスタ番号を列に追加
centers$cluster <- rownames(centers)
centers_long <- centers %>%
pivot_longer(cols = -cluster, names_to = "variable", values_to = "value") %>%
mutate(clust = paste("cluster", cluster, sep = ""))
# 折れ線グラフを作成
ggplot(centers_long, aes(x = variable, y = value, group = cluster, color = cluster)) +
geom_line() +
geom_point() +  # データ点を追加
labs(title = "Cluster Centers", x = "Variable", y = "Center Value") +
theme_minimal()
# clusterごとのプロットと合わせる
vsd_avg_plot <- vsd_avg_with_cust_info %>%
gather(key = "variable" , value = "value", -clust) %>%  # 'clust'は対象から除く
group_by(variable) %>%
mutate(cluster =  1:n())
p_cluster <- ggplot(vsd_avg_plot, aes(x =  variable , y = value , group = cluster)) +
geom_point() +
geom_line(alpha = 1 ,col = "gray") +
theme_bw() +
theme(legend.position = "none" , axis.text.x = element_blank()) +
facet_wrap(~clust) +
geom_line(data = centers_long, aes(x = variable, y = value, group = cluster, colour = as.character(clust)), alpha = 0.80, size = 0.5) +
labs(x = "Time", y = "normalised count")
# 全クラスターの折れ線
p_all <- ggplot(centers_long, aes(x = variable, y = value, group = cluster, color = cluster)) +
geom_line() +
theme_bw() +
theme(legend.position = "none", axis.text.x =  element_blank(),
axis.title.x = element_blank(), axis.title.y = element_blank())
overall_center <- centers_long %>%
mutate(clust = "Overall")
# 元のcenters_longに追加
centers_long_combined <- bind_rows(centers_long, overall_center)
# 作図
p_cluster_combined <- ggplot(vsd_avg_plot, aes(x =  variable , y = value , group = cluster)) +
geom_point(alpha = 0.5) +
geom_line(alpha = 1 ,col = "lightgray") +
theme_bw() +
theme(legend.position = "none" , axis.text.x = element_blank()) +
facet_wrap(~clust) +
geom_line(data = centers_long_combined, aes(x = variable, y = value, group = cluster, colour = as.character(cluster)), alpha = 0.80, size = 0.5) +
labs(x = "Time", y = "Z-score")
p_cluster_combined
ggsave("ClusterCombined_Z-score.pdf", width = 10, height = 10)
# cluster情報をZ-score tableに追加
Z2 <- as.data.frame(Z)
Z2$Cluster <- kmeans_result$cluster
# Cluster順に
Z2 <- Z2[order(Z2$Cluster), ]
# longerに
Z2_long <- Z2 %>%
rownames_to_column("Pathway") %>%
pivot_longer(-c(Pathway, Cluster), names_to = "Time", values_to = "Zscore")
# heatmapに
ggplot(Z2_long, aes(x = Time, y = reorder(Pathway, Cluster), fill = Zscore)) +
geom_tile() +  # ヒートマップを描く
scale_fill_gradient2(low = "blue", mid = "white", high = "red") + # カラースケール
theme_minimal() +
theme(axis.text.x = element_text(angle = 90, vjust = 0.5, hjust=1), axis.text.y = element_blank()) +
labs(x = "Time", y = "Gene")
custom_order <- c("3", "5", "7", "4", "2", "1", "6")
Z2_long$Cluster <- factor(Z2_long$Cluster, levels = custom_order)
# クラスター順に並べる
Z2_long <- Z2_long %>%
arrange(Cluster, Pathway)  # Cluster順に並び替え
# Pathway列をCluster順に並べた順序でfactor化する
Z2_long$Pathway <- factor(Z2_long$Pathway, levels = unique(Z2_long$Pathway))
p_heatmap_order <- ggplot() +
geom_tile(data = Z2_long, aes(x = Time, y = Pathway, fill = Zscore)) +
scale_fill_gradient2(low = "#301847", high = "red") +
theme_minimal() +
theme(axis.text.x = element_blank(), axis.text.y = element_blank()) +
labs(x = "Time", y = "Gene")
p_heatmap_order
ggsave("Gene_Heatmap_Order_250117.pdf", width = 10, height = 20)
