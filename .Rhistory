library(ggplot2)
library(scales)
library(DESeq2)
library(EnhancedVolcano)
library(vsn)
library(DEGreport)
library(viridis)
library(tidyr)
library(tidyverse)
library(org.EcK12.eg.db)
library(clusterProfiler)
library(ggnewscale)
library(ggsci)
library(openxlsx)
library(paletteer)
library(ggwordcloud)
library(patchwork)
library(grid)
palette2 <- rev(viridis(48))
setwd("~/Desktop/BacteriaRNA-Seq/DESeq2-Heatmap")
###### 1. ID-SYMBOL対応表 #######
id_identity <- read.table("id-type-name.txt")
colnames(id_identity) <- c("gene_id","identity","gene_name")
# insI2がなぜか2つあったので別の名前をそれぞれつける
id_identity <- id_identity %>%
mutate(gene_name = ifelse(gene_id == "b1404",
str_replace(gene_name, "insI2", "InsI2.1"),
gene_name)) %>%
mutate(gene_name = ifelse(gene_id == "b4708",
str_replace(gene_name, "insI2", "InsI2.2"),
gene_name))
###### 2. count #######
count <- read.table("count_matrix.txt", header=1) %>%
left_join(id_identity, "gene_id") %>%
filter(!duplicated(gene_name)) %>%
column_to_rownames("gene_name") %>%
select(-"gene_id", -"identity")
###### 3. 1M未満 except #######
ex_samples <- readLines("Count_FAIL.list")
count <- count[, !(colnames(count) %in% ex_samples)]
###### 4. Sample information #######
sample <- read.table("sample_down.txt", header=1)
sample <- sample %>%
filter(!(sample_id %in% ex_samples))
##### 5. サンプルのリード数データ #####
num_reads <- read.table("Count_summary.txt", header = FALSE)
colnames(num_reads) <- c("sample_id","count","states")
restlist <- id_identity %>%
filter(identity != "rRNA") %>%
select(-gene_id, -identity)
restlist <- as.vector(restlist$gene_name)
count_Norrna <- count %>%
filter(row.names(.) %in% restlist)
model.matrix(~ sample$sample_type)
#----------
# rRNAなし
dds_Norrna <- DESeqDataSetFromMatrix(countData = round(count_Norrna), colData = sample, design= ~ sample_type)
nrow(dds_Norrna) # 4617
# 4サンプル以上で10カウント以上の遺伝子を残す（マニュアルの方法）
smallestGroupSize <- 4
keep_Norrna <- rowSums(counts(dds_Norrna) >= 10) >= smallestGroupSize
dds_Norrna <- dds_Norrna[keep_Norrna,]
nrow(dds_Norrna) # 3663
# 正規化（今回はサンプル数が多いためvstを選択）
vsd_Norrna <- vst(dds_Norrna, blind = FALSE)
head(assay(vsd_Norrna), 3)
vsd_mat_Norrna <- assay(vsd_Norrna)
######----------rRNAなし----------#####
# Likelihood ratio test
dds_Norrna <- estimateSizeFactors(dds_Norrna) #遺伝子発現の差分解析
dds_Norrna <- estimateDispersions(dds_Norrna) #遺伝子発現の差分解析
dds_Norrna <- nbinomLRT(dds_Norrna, full = ~ sample_type, reduced = ~ 1) #遺伝子発現の差分解析
#11 rows did not converge in beta, labelled in mcols(object)$fullBetaConv. Use larger maxit argument with nbinomLRTと出る。これを除く（https://support.bioconductor.org/p/65091/）
dds_Norrna_Clean <- dds_Norrna[which(mcols(dds_Norrna)$fullBetaConv),]
nrow(dds_Norrna) # 3663
nrow(dds_Norrna_Clean) # 3652
# Extract results
res_Norrna <- results(dds_Norrna_Clean)
# Subset the LRT results to return genes with padj < 0.05
sig_res_Norrna <- res_Norrna %>%
data.frame() %>%
rownames_to_column(var="gene") %>%
as_tibble() %>%
filter(padj < 0.05)
# Get sig gene lists
sigLRT_genes_Norrna <- sig_res_Norrna %>%
pull(gene)
length(sigLRT_genes_Norrna) # 3617
# Clustering
clustering_sig_genes_Norrna <- sigLRT_genes_Norrna
cluster_vst_Norrna <- vsd_mat_Norrna[rownames(vsd_mat_Norrna) %in% clustering_sig_genes_Norrna, ]
nrow(cluster_vst_Norrna) # 3617
